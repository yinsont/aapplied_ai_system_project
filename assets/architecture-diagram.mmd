graph TD
    A["🧑 User Input<br/>(free-form text)"] --> B["🛡️ Input Validator<br/>(guardrails)"]
    B -->|"❌ rejected"| R["⚠️ Error Response<br/>(reason logged)"]
    B -->|"✅ valid"| C["🧹 Text Sanitizer"]
    C --> D{"Analysis Mode?"}
    D -->|"keyword"| E["📝 Keyword Analyzer<br/>(18 rule sets)"]
    D -->|"AI"| F["🤖 Anthropic API<br/>(Claude Sonnet)"]
    F -->|"parse fail"| E
    E --> G["🎭 MoodAnalysis<br/>(mood, energy, valence,<br/>genre, confidence)"]
    F --> G
    G --> H["👤 UserProfile<br/>Conversion"]
    H --> I["📊 Scoring Engine<br/>(weighted formula)"]
    J["💾 Song Catalog<br/>(100 songs, CSV)"] --> I
    I --> K["🏆 Ranked Results<br/>(top-k songs)"]
    K --> L["💬 Explanation<br/>Generator"]
    L --> M["🎧 Playlist Output<br/>(songs + scores +<br/>explanations)"]

    N["📋 Logger"] -.->|"logs all decisions"| B
    N -.-> E
    N -.-> F
    N -.-> I

    style A fill:#1e293b,stroke:#60a5fa,color:#fff
    style B fill:#1e293b,stroke:#f59e0b,color:#fff
    style R fill:#1e293b,stroke:#ef4444,color:#fff
    style G fill:#1e293b,stroke:#a78bfa,color:#fff
    style I fill:#1e293b,stroke:#10b981,color:#fff
    style M fill:#1e293b,stroke:#60a5fa,color:#fff
    style N fill:#1e293b,stroke:#94a3b8,color:#fff
